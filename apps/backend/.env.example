DATABASE_URL=
DIRECT_URL=
PORT=3001
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Optional. Leave empty in Render to use Luffy's local rule-based interpreter.
OLLAMA_BASE_URL=
OLLAMA_MODEL=qwen2.5:3b

STT_PROVIDER=groq
GROQ_API_KEY=
GROQ_STT_MODEL=whisper-large-v3-turbo
# Optional request timeout in milliseconds.
GROQ_STT_TIMEOUT_MS=20000

# Local development alternative: STT_PROVIDER=faster-whisper
STT_PYTHON_PATH=
STT_MODEL=tiny
STT_SIMULATED_FALLBACK=false
